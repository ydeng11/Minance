{
  "name": "minance-next",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace @minance/web -- -p 3000",
    "dev:api": "env PORT=3001 tsx services/api/src/server.ts",
    "build:web": "npm run build --workspace @minance/web",
    "start": "concurrently -k \"npm run start:api\" \"npm run start:web\"",
    "start:web": "npm run start --workspace @minance/web -- -p 3000",
    "start:api": "env PORT=3001 tsx services/api/src/server.ts",
    "migrate:sqlite": "tsx scripts/migrate-json-to-sqlite.ts",
    "validate:sqlite": "tsx scripts/validate-json-vs-sqlite.ts",
    "seed:fixture": "tsx scripts/seed-deterministic-fixture.ts",
    "test:test-first": "tsx --test scripts/check-frontend-test-first.test.ts && tsx scripts/check-frontend-test-first.ts",
    "test": "npm run test:test-first && tsx --test services/api/test/**/*.test.ts && npm run test --workspace @minance/web",
    "check": "npm run test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --project=chromium --headed",
    "e2e:ci": "playwright test --project=chromium",
    "e2e:a11y": "playwright test --project=chromium --grep @a11y"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "axe-core": "^4.11.0",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "csv-parse": "^5.6.0"
  }
}
