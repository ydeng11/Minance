{
  "name": "minance-next",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace @minance/web -- -p 3000",
    "dev:api": "env PORT=3001 node services/api/src/server.js",
    "build:web": "npm run build --workspace @minance/web",
    "start": "concurrently -k \"npm run start:api\" \"npm run start:web\"",
    "start:web": "npm run start --workspace @minance/web -- -p 3000",
    "start:api": "env PORT=3001 node services/api/src/server.js",
    "migrate:sqlite": "node scripts/migrate-json-to-sqlite.mjs",
    "validate:sqlite": "node scripts/validate-json-vs-sqlite.mjs",
    "test:test-first": "node --test scripts/check-frontend-test-first.test.mjs && node scripts/check-frontend-test-first.mjs",
    "test": "npm run test:test-first && node --test services/api/test/**/*.test.js && npm run test --workspace @minance/web",
    "check": "npm run test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --project=chromium --headed",
    "e2e:ci": "playwright test --project=chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "csv-parse": "^5.6.0"
  }
}
