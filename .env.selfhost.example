# Copy to .env.selfhost before running docker-compose.selfhost.yml
# This template is for the Docker self-host stack. For local pnpm development, use .env.local instead.

# Public service ports on the host machine
MINANCE_WEB_PORT=3000
MINANCE_API_PORT=3001

# Runtime data mount source for /var/lib/minance inside the API container.
# Leave unset to keep the Docker-managed named volume (`minance_data`).
# Set to ./services/api/data to reuse the repo's existing SQLite/runtime data directory.
# MINANCE_RUNTIME_DATA_SOURCE=./services/api/data

# Required secret: rotate before first production launch.
# Minimum recommendation: 32+ random bytes in hex/base64.
AI_CREDENTIAL_SECRET=replace-with-a-long-random-secret

# Baseline runtime toggles for the stock Docker self-host stack
MINANCE_STORE_BACKEND=sqlite
MINANCE_SQLITE_AUTO_INIT=true
MINANCE_SEED_TEST_ACCOUNT=false
MINANCE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MINANCE_CORS_ALLOW_CREDENTIALS=false
MINANCE_RATE_LIMIT_WINDOW_MS=60000
MINANCE_RATE_LIMIT_MAX_REQUESTS=600
MINANCE_AUTH_RATE_LIMIT_MAX_REQUESTS=60

# Optional path overrides.
# docker-compose.selfhost.yml already sets these container paths; uncomment only if you customize
# the compose file or run the API outside the stock compose stack.
# MINANCE_DATA_FILE=/var/lib/minance/store.json
# MINANCE_SQLITE_FILE=/var/lib/minance/minance.sqlite
# MINANCE_SQLITE_SCHEMA_FILE=/app/services/api/sql/schema.sql
# MINANCE_TRAINING_DB_PATH=/var/lib/minance/training.db

# Optional AI/import/runtime feature flags.
# AI_LLM_CATEGORIZATION_ENABLED=true
# AI_LLM_ASSISTANT_SYNTHESIS_ENABLED=true
# IMPORT_PROCESSED_EDITOR_ENABLED=true
# IMPORT_PROCESSING_LOGS_ENABLED=false
# IMPORT_DIRECTION_INFERENCE_ENABLED=true
# IMPORT_DIRECTION_LLM_ENABLED=true
# AI_CREW_ANALYSIS_ENABLED=true
# CREWAI_PYTHON_BIN=python3
# AI_CREW_ANALYSIS_TIMEOUT_MS=8000
# AI_LLM_TIMEOUT_MS=16000

# Optional BYOK provider defaults for bootstrapping a user in non-production only.
# Keep unset in production unless intentionally pre-seeding.
OPENROUTER_API_KEY=
DEV_TEST_ACCOUNT_EMAIL=
DEV_TEST_ACCOUNT_PASSWORD=

# Optional backup controls used by scripts/selfhost-backup.sh and scripts/selfhost-restore.sh
# When MINANCE_RUNTIME_DATA_SOURCE=./services/api/data, these defaults already point at the same host directory.
MINANCE_BACKUP_ROOT=./backups
MINANCE_RUNTIME_DATA_DIR=./services/api/data
MINANCE_UPLOAD_DIR=./services/api/data/uploads
