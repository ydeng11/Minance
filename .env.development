# Tracked development runtime settings. Just rebuilds the ignored SQLite
# working database from the tracked deterministic JSON fixture before startup.
NODE_ENV=development
MINANCE_STORE_BACKEND=sqlite
MINANCE_SQLITE_FILE=services/api/tmp/dev-minance.sqlite
MINANCE_SQLITE_SCHEMA_FILE=services/api/sql/schema.sql
MINANCE_SEED_TEST_ACCOUNT=false
