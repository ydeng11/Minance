# Tracked development runtime settings. Just rebuilds the tracked development
# database from the deterministic JSON fixture before startup.
NODE_ENV=development
MINANCE_STORE_BACKEND=sqlite
MINANCE_SQLITE_FILE=services/api/data/development-minance.sqlite
MINANCE_SQLITE_SCHEMA_FILE=services/api/sql/schema.sql
MINANCE_SEED_TEST_ACCOUNT=false
